# ─────────────────────────────────────────────────────────────────────────────
# The Machine — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key   # server-side only, bypasses RLS

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte random string used to derive per-user AES-256-GCM keys.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Changing this will invalidate all existing encrypted credentials.

SERVER_SECRET=your-32-byte-random-secret-here

# ── Storage ───────────────────────────────────────────────────────────────────
# Supabase Storage bucket name for knowledge base file uploads.
# Create this bucket in your Supabase dashboard (set to private).

STORAGE_BUCKET=knowledge

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# These are prefixed with VITE_ so Vite exposes them to the browser.
# Never put secrets here — these values are visible in the browser bundle.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE_URL=http://localhost:8000
